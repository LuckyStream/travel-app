# Ollama (server-side; Next.js API routes call this host from your machine)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Mapbox (browser; optional — map shows setup instructions without it)
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Places + Geocoding + Distance Matrix (server-side; generate-plan + itinerary travel times)
# Enable Places API, Geocoding API, and Distance Matrix API for the same key if you want routed drive times.
# https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=
